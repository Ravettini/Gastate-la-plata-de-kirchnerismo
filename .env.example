# Copiá a .env.local (no se sube a git) o configurá en Vercel → Settings → Environment Variables.
#
# Contraseña: NUNCA en texto plano en el repo. Solo el hash bcrypt:
#   node -e "const b=require('bcryptjs'); console.log(b.hashSync('TU_PASS',10))"
#
DASHBOARD_EMAIL=polijuegos@gmail.com
DASHBOARD_PASSWORD_HASH=
# Secreto largo y aleatorio para firmar la cookie de sesión (mín. 24 caracteres).
DASHBOARD_SESSION_SECRET=

# Opcional en Vercel: almacén Redis/KV para que los eventos persistan entre deploys.
# Sin esto, en Vercel los eventos viven solo en memoria del lambda (se pierden al apagarse).
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
