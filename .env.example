# Panel /dashboard y visitas globales (API /api/*)
#
# Local: copiá a .env.local (ignorado por git) y `npm run dev`.
# Vercel: Project → Settings → Environment Variables.

DASHBOARD_EMAIL=polijuegos@gmail.com
DASHBOARD_PASSWORD=
DASHBOARD_SESSION_SECRET=

# Recomendado en producción: Vercel → Storage → Redis/KV (variables KV_REST_*).
# Sin KV en Vercel, los eventos quedan solo en memoria del lambda (se pierden al enfriarse).
